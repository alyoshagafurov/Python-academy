# Frontend env (optional). In dev, Vite proxies /api → backend, so leave empty.

# Same-origin by default ("" → /api proxied to the backend). Set to an absolute
# API URL only if you serve the frontend separately from the API in production.
# VITE_API_BASE=

# Where Vite's dev proxy forwards /api (defaults to http://127.0.0.1:8077).
# VITE_API_TARGET=http://127.0.0.1:8077
