# ─── Python Knowledge Hub — Web API settings ───────────────────────────────
# Copy to `.env` and adjust. Every value has a sane default for local dev.

# Path to the Telegram bot project (its academy.db + content are reused).
# Default: a sibling folder ../python-academy-bot — usually no need to set this.
# BOT_DIR=/Users/you/python-academy-bot

# Secret used to sign session cookies. CHANGE THIS in production.
SESSION_SECRET=dev-insecure-secret-change-me
SESSION_MAX_AGE_DAYS=30
# Set to 1 only when serving over HTTPS (production).
COOKIE_SECURE=0

# ── Telegram Login Widget (production) ──
# The REAL bot token — required to verify Telegram logins. Leave empty locally.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=python_academy_tj_bot
TELEGRAM_AUTH_MAX_AGE=86400

# ── Dev login (local testing) ──
# When on (1), /api/auth/dev lets you log in as any user_id without Telegram.
# TURN THIS OFF (0) in production.
DEV_AUTH=1

# Browser origins allowed to call the API (Vite dev server).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
