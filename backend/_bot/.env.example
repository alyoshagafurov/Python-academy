# === Python Academy — environment template ===
# Copy this file to .env and fill in your own values.
# Get a token from @BotFather in Telegram.
BOT_TOKEN=PASTE_NEW_TOKEN_HERE

# Path to the SQLite database file (relative to project root)
DB_PATH=academy.db

# Admin Telegram IDs (comma-separated) — unlock /admin, /grant_pro, /revoke_pro.
ADMIN_IDS=

# Users with PRO unlocked by config (comma-separated).
PRO_IDS=

# Turn on the Telegram Stars checkout (1/true/yes/on). Off ⇒ buying shows a
# "contact admin" message instead of an invoice. Stars need NO provider token.
PAYMENTS_ENABLED=
